# Copy this file to .env and fill in real values (never commit .env to git)
YOUTUBE_API_KEY=AIzaSyDxxxxxxxxxxxxxx
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxx
CLAUDE_API_KEY=sk-ant-xxxxxxxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=123456789123456
INSTAGRAM_ACCESS_TOKEN=EAA123456789xxx

# Paste the entire contents of google_credentials.json as a single line here
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Optional — get a free key at unsplash.com/developers for real Islamic photos
# Without this, a generated geometric background is used instead
UNSPLASH_ACCESS_KEY=

# Optional — public HTTPS URL of the video file for Instagram Reels upload
# Instagram cannot reach local files; host the video on S3/GCS/CDN first
INSTAGRAM_VIDEO_HOST_URL=

# Email notifications (GitHub Actions only — not needed for local Docker runs)
# GMAIL_USERNAME: your Gmail address
# GMAIL_APP_PASSWORD: generate at Google Account → Security → 2-Step Verification → App passwords
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
